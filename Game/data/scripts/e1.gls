
platform_range :: Vector2.{ 0.0, 3.0 }?;

for left_platform, right_platform {
    cycle_lerp := cycle_over_random(time, 5.0, 8.0, true, true);
    set_next_offset(it, circle(cycle_lerp, 0.0) * platform_range);
}

for  members_of(fire_bar) {
    cycle_lerp := cycle_over_random(time, 2.0, 4.0, true, true);
    do_fire_bar(it.position, cycle_lerp, 5, 0.75, 1.0, 0.75);
}